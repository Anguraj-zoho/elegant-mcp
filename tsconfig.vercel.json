{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "jsx": "react-jsx"
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}
